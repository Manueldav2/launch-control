# Launch Control — environment.
# Copy to .env.local and fill in. NEVER commit real keys (.env* is gitignored).

# Claude (the brains: research + the 7-day plan + per-channel copy + the critic).
# Opus 4.8 is the default model — it does the strategy and the self-grading.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# fal.ai — UGC video (AI person-to-camera), motion/launch video, and images.
# Cost guard: keep total video spend small. Stills are cheap, video is not.
FAL_KEY=
FAL_VIDEO_MODEL=fal-ai/veo3.1/fast/image-to-video
FAL_IMAGE_MODEL=fal-ai/flux/dev

# Zernio — connect + post to X / LinkedIn / Instagram / Facebook / TikTok.
# (Publishing only — it posts to YOUR connected accounts; it cannot search
#  competitors. Competitor CTA mining is Bright Data's job, below.)
ZERNIO_API_KEY=
ZERNIO_BASE_URL=https://zernio.com/api

# Bright Data — OPTIONAL competitor intel. Scrapes peer X / LinkedIn / Instagram
# posts so the planner designs to CTAs that actually win. The app works WITHOUT
# it (the competitor signal is simply skipped). Free tier: 5,000 credits/mo, no
# card. Token:  brightdata.com -> Account settings -> API keys (cp/setting/users).
# Dataset IDs: brightdata.com/cp/scrapers/browse -> open the scraper -> "API" tab.
# Only the X posts dataset id is published in the docs; set IG/LinkedIn yourself.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_X_DATASET=gd_lwxkxvnf1cynvib9co
BRIGHTDATA_IG_DATASET=
BRIGHTDATA_LI_DATASET=

# Supabase — persistence for generated media + week plans, AND the review queue
# the image critic consumes. The creation app works WITHOUT these (localStorage
# + render URLs); the REVIEWER (npm run review) requires them. New-format
# sb_secret_… / sb_publishable_… keys work, as do legacy service-role / anon
# JWTs. Run docs/supabase-schema.sql in a fresh project, then paste URL + key.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Image critic (the reviewer) — a decoupled consumer of the assets queue.
# See docs/review-contract.md. Needs SUPABASE_* above + (ideally) ANTHROPIC_API_KEY
# so Opus actually LOOKS at each image; without a key it degrades to a header
# heuristic. Run with `npm run review` (or POST /api/review on a cron).
REVIEWER_ID=critic-1          # stable id for this reviewer (lands in claimed_by + review)
REVIEW_MAX_VERSIONS=3         # after N versions a still-failing image is rejected, not regenerated
REVIEW_POLL_MS=4000           # wait between empty polls
REVIEW_CLAIM_TTL_MS=300000    # a claim older than this with no verdict is requeued (crash recovery)
REVIEW_ORG=                   # restrict to one org's queue; empty = all orgs
REVIEW_CRON_SECRET=           # if set, POST /api/review requires it (Bearer / x-review-secret). Empty = open.

# App
PUBLIC_BASE_URL=http://localhost:3000
# Daily video spend ceiling in USD — the media engine refuses to exceed it.
MAX_VIDEO_SPEND_USD=20
