# Launch Control — environment keys. Copy to .env.local for local dev, and set
# the same on your host (Vercel: Project -> Settings -> Environment Variables).
# The platform runs on THESE server keys; users never need their own (though they
# can bring their own fal.ai / Anthropic key from the in-app "Bring your own keys"
# panel). Set everything under REQUIRED so nothing runs in a degraded mode.
# NEVER commit real keys (.env.local is gitignored; this file is placeholders only).

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Claude (Opus 4.8): research, the 7-day plan, per-channel copy, the self-grading
# critic, and the multimodal visual critic.
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai: images, UGC video (person-to-camera), motion/launch video.
FAL_KEY=xxxxxxxx:xxxxxxxx

# Zernio: connect + publish + schedule to X / LinkedIn / Instagram / TikTok, and
# read comments for the watcher.
ZERNIO_API_KEY=sk_...

# Supabase (server): accounts, saved projects, media storage, the free-tier quota,
# and the comment-watcher dedup. Use the SERVICE ROLE key here.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...            # service_role JWT

# Supabase (browser): email/password sign-in runs client-side with the PUBLIC
# anon key. Both must be set or sign-in is unavailable (and generation is gated
# on sign-in).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon (public) JWT

# The deployed origin, so OAuth connect redirects return to the right place.
PUBLIC_BASE_URL=https://your-app.vercel.app

# ── COMMENT WATCHER ───────────────────────────────────────────────────────────
# "1" lets the watcher POST replies live to every new comment on every platform.
# Unset = draft-only. The Vercel Cron in vercel.json runs the watcher on a cadence;
# the /watch page is the live, in-demo view of the same loop.
AUTO_REPLY_COMMENTS=1
# Optional: protect /api/cron/watch. If set, Vercel Cron sends it automatically,
# but the live /watch page can no longer poll the endpoint (it holds no secret).
# CRON_SECRET=some-long-random-string
# Recent posts per account the watcher scans each run (default 50).
# WATCH_POSTS_PER_ACCOUNT=50

# ── OPTIONAL (sensible defaults) ──────────────────────────────────────────────
ANTHROPIC_MODEL=claude-opus-4-8
FAL_VIDEO_MODEL=fal-ai/veo3.1/fast/image-to-video
FAL_IMAGE_MODEL=fal-ai/flux/dev
ZERNIO_BASE_URL=https://zernio.com/api
SUPABASE_ANON_KEY=eyJ...               # server-side fallback if service key absent
SUPABASE_MEDIA_BUCKET=media
MAX_VIDEO_SPEND_USD=20                  # fal spend ceiling; the engine refuses to exceed it
FREE_IMAGES=1                           # free image renders per account
FREE_VIDEOS=1                           # free video renders per account
LUMA_API_KEY=                           # optional event pages; else users connect their own Luma

# Bright Data — OPTIONAL competitor intel. Scrapes peer X / LinkedIn / Instagram
# posts so the planner designs to CTAs that actually win. The app works WITHOUT
# it (the competitor signal is simply skipped). Free tier: 5,000 credits/mo, no
# card. Token:  brightdata.com -> Account settings -> API keys (cp/setting/users).
# Dataset IDs: brightdata.com/cp/scrapers/browse -> open the scraper -> "API" tab.
# Only the X posts dataset id is published in the docs; set IG/LinkedIn yourself.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_X_DATASET=gd_lwxkxvnf1cynvib9co
BRIGHT_DATA_IG_DATASET=gd_l1vikfch901nx3by4
BRIGHT_DATA_LI_DATASET=gd_l1viktl72bvl7bjuj0
# TikTok (gd_l1villgoiiidt09ci) is also accessible but not wired — not a content platform.

# Weather needs NO key (Open-Meteo, keyless).
# One-time DB setup: run docs/supabase-schema.sql in the Supabase SQL editor
# (creates the assets, plans, usage, handled_comments tables + the media bucket).
