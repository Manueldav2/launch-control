# Launch Control — environment.
# Copy to .env.local and fill in. NEVER commit real keys (.env* is gitignored).

# Claude (the brains: research + the 7-day plan + per-channel copy + the critic).
# Opus 4.8 is the default model — it does the strategy and the self-grading.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# fal.ai — UGC video (AI person-to-camera), motion/launch video, and images.
# Cost guard: keep total video spend small. Stills are cheap, video is not.
FAL_KEY=
FAL_VIDEO_MODEL=fal-ai/veo3.1/fast/image-to-video
FAL_IMAGE_MODEL=fal-ai/flux/dev

# Zernio — connect + post to X / LinkedIn / Instagram / Facebook / TikTok.
ZERNIO_API_KEY=
ZERNIO_BASE_URL=https://zernio.com/api

# Luma — programmatically create real event pages for event-mode launches.
# Auth is a single API key (Luma has no third-party OAuth): Settings -> dev/API
# in Luma, paste here OR via the in-app Connect button. Sent as x-luma-api-key.
LUMA_API_KEY=

# Weather — NO KEY NEEDED. The event-day forecast + rain/move-day decision uses
# Open-Meteo (free, keyless). Listed here only so it's documented; nothing to set.

# Supabase — OPTIONAL persistence for generated media + week plans.
# The app works WITHOUT these (localStorage + render URLs). Add them to persist
# server-side + across devices. Free project at supabase.com, run
# docs/supabase-schema.sql, then paste the project URL + keys.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Anon key + the Storage bucket used for rendered media (defaults to "media").
SUPABASE_ANON_KEY=
SUPABASE_MEDIA_BUCKET=media

# App
PUBLIC_BASE_URL=http://localhost:3000
# Daily video spend ceiling in USD — the media engine refuses to exceed it.
MAX_VIDEO_SPEND_USD=20
